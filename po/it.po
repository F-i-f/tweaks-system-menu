#: schemas/org.gnome.shell.extensions.tweaks-system-menu.gschema.xml:7
msgid "Buttons Position"
msgstr "Posizione dei pulsanti"

#: schemas/org.gnome.shell.extensions.tweaks-system-menu.gschema.xml:8
#, fuzzy
msgid ""
"If set to -1, the position is automatic: buttons will show up after "
"Settings. If set to zero or more, the actual buttons' position on the system "
"menu."
msgstr ""
"Se impostato a -1, la posizione è automatica: i pulsanti verranno mostrati "
"dopo Impostazioni. Se impostato a zero o più, indica la posizione effettiva "
"dei pulsanti nel menu di sistema."

#: schemas/org.gnome.shell.extensions.tweaks-system-menu.gschema.xml:16
msgid "List of applications to show"
msgstr "Elenco delle applicazioni da mostrare"

#: schemas/org.gnome.shell.extensions.tweaks-system-menu.gschema.xml:17
msgid "List of applications to display in the system menu."
msgstr "Elenco delle applicazioni da visualizzare nel menu di sistema."

#: schemas/org.gnome.shell.extensions.tweaks-system-menu.gschema.xml:22
msgid "Debugging."
msgstr "Debug."

#: schemas/org.gnome.shell.extensions.tweaks-system-menu.gschema.xml:23
msgid "Enable debugging for the extension."
msgstr "Abilita il debug per l’estensione."

